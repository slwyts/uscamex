# Deployment wallet
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Required project owner address
PROJECT_OWNER=0x0000000000000000000000000000000000000000

# Network RPC endpoints
BSC_MAINNET_RPC_URL=https://bsc-dataseed.binance.org/
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# Public frontend admin defaults
NEXT_PUBLIC_RPC_URL=https://bsc-dataseed.binance.org/
NEXT_PUBLIC_CHAIN_ID=56
NEXT_PUBLIC_MANAGER_ADDRESS=
NEXT_PUBLIC_TOKEN_ADDRESS=
NEXT_PUBLIC_REWARD_ENGINE_ADDRESS=

# Optional fork test settings
BSC_RPC_URL=
BSC_FORK_BLOCK=

# Optional deployment overrides
PANCAKE_ROUTER=
INITIAL_LIQUIDITY_BNB=10

# Operation mode: 0 = NODE_SALE, 1 = DEPOSIT
OPERATION_MODE=0

# Buy switch after deployment
BUY_ENABLED=false